<UserControl x:Class="Nesti.Controls.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
             Width="360"
             Margin="0,0,0,8">

    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="CardScale"
                            ScaleX="1" ScaleY="1"
                            CenterX="180" CenterY="36" />
            <TranslateTransform x:Name="SlideTransform" />
        </TransformGroup>
    </UserControl.RenderTransform>

    <Grid>

        <!-- Shadow layer — drawn BEHIND the card, offset down-right by 2 px -->
        <Border CornerRadius="13"
                Margin="2,3,0,0"
                IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush po:Freeze="True" Color="#000000" Opacity="0.09" />
            </Border.Background>
        </Border>

        <!-- Card — white background with a subtle border, no GPU Effect -->
        <Border x:Name="Card"
                BorderThickness="1"
                CornerRadius="12"
                Padding="4"
                Cursor="Hand"
                MouseLeftButtonDown="Card_Click">
            <Border.Background>
                <SolidColorBrush po:Freeze="True" Color="White" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush po:Freeze="True" Color="#E5E7EB" />
            </Border.BorderBrush>

            <Grid Margin="12,8,8,8">

                <!-- Title + message -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleBlock"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,32,0" />
                    <TextBlock x:Name="MessageBlock"
                               FontSize="12"
                               FontWeight="Normal"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"
                               MaxHeight="36"
                               Margin="0,3,32,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Dismiss button only -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">

                    <Border x:Name="DismissBtn"
                            Width="24" Height="24"
                            Background="Transparent"
                            Cursor="Hand"
                            ToolTip="Dismiss"
                            MouseLeftButtonDown="Dismiss_MouseDown"
                            MouseLeftButtonUp="Dismiss_MouseUp">
                        <Image Source="pack://application:,,,/assets/cross_button_notif_icon.png"
                               Width="22" Height="22"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
