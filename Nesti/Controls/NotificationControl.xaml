<UserControl x:Class="Nesti.Controls.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420"
             Margin="0,0,0,8">

    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="CardScale"
                            ScaleX="1" ScaleY="1"
                            CenterX="210" CenterY="36" />
            <TranslateTransform x:Name="SlideTransform" />
        </TransformGroup>
    </UserControl.RenderTransform>

    <Border x:Name="Card"
            Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="12"
            Padding="4"
            Cursor="Hand"
            MouseLeftButtonDown="Card_Click">

        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Opacity="0.10"
                              BlurRadius="4"
                              ShadowDepth="3"
                              Direction="270" />
        </Border.Effect>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Bird avatar -->
            <Border Grid.Column="0"
                    Width="48" Height="48"
                    CornerRadius="12"
                    VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="#3B82F6" />
                </Border.Background>
                <Image x:Name="AvatarImage"
                       Width="32" Height="32"
                       Stretch="Uniform" />
            </Border>

            <!--
                Content column — single Grid cell shared by text and action buttons.
                Text is vertically centered; buttons are overlaid at the top-right corner
                using alignment only. Everything is one hit-test region, fixing the hover
                and click detection issues caused by separate fixed-width button columns.
                Buttons use Border (not Button) so MouseLeftButtonDown is owned directly:
                  e.Handled=true  → stops event bubbling to Card_Click
                  CaptureMouse()  → guarantees MouseLeftButtonUp fires on this element
                                    even if the cursor moves between press and release
            -->
            <Grid Grid.Column="1" Margin="12,0,4,0">

                <!-- Title + message -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleBlock"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,56,0" />
                    <TextBlock x:Name="MessageBlock"
                               FontSize="12"
                               FontWeight="Normal"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"
                               MaxHeight="36"
                               Margin="0,2,56,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Action buttons — always visible, overlaid top-right -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">

                    <Border x:Name="SnoozeBtn"
                            Width="24" Height="24"
                            Background="Transparent"
                            Cursor="Hand"
                            ToolTip="Snooze"
                            MouseLeftButtonDown="Snooze_MouseDown"
                            MouseLeftButtonUp="Snooze_MouseUp">
                        <Image Source="pack://application:,,,/assets/snooze_icon.png"
                               Width="22" Height="22"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <Border x:Name="DismissBtn"
                            Width="24" Height="24"
                            Background="Transparent"
                            Cursor="Hand"
                            Margin="4,0,0,0"
                            ToolTip="Dismiss"
                            MouseLeftButtonDown="Dismiss_MouseDown"
                            MouseLeftButtonUp="Dismiss_MouseUp">
                        <Image Source="pack://application:,,,/assets/cross_button_notif_icon.png"
                               Width="22" Height="22"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</UserControl>
