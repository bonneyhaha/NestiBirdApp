# ============================================================
# NESTI BIRD ASSISTANT — CONFIGURATION
# Edit this file and restart the app to apply changes.
# ============================================================


# ── WebSocket ──────────────────────────────────────────────
# Base WebSocket URL.  Final connection URL = {WS_URL}/{mEmpID}
# mEmpID is fetched from API_BASE_URL at startup (see below).
WS_URL=wss://your-websocket-server.com/ws

# Base delay (ms) before first reconnect attempt.
# Doubles on each attempt + ±10% jitter (exponential back-off).
WS_RECONNECT_BASE_MS=2000

# Stop retrying after this many failed attempts.
WS_RECONNECT_MAX_ATTEMPTS=10


# ── REST API ───────────────────────────────────────────────
# User-ID lookup endpoint (called once at startup).
#   Request :  GET {API_BASE_URL}?CorpID=Corp\{windowsLoginName}
#   Response:  JSON containing "mEmpID"
# mEmpID is appended to WS_URL and used as userSession in all payloads.
# Leave blank to connect to WS_URL directly without a lookup.
API_BASE_URL=http://your-api-server.com/api/user/id

# Endpoint to fetch the employee's full display name (optional).
#   Request :  GET {API_BASE_URL}{API_GET_FULLNAME_PATH}?username={windowsLogin}
#   Response:  { "fullName": "Jane Doe" }
# Leave blank to skip name resolution.
API_GET_FULLNAME_PATH=/api/user/fullname


# ── App behavior ───────────────────────────────────────────
# URL opened in the default browser when the bird is clicked.
BIRD_DEFAULT_URL=https://your-app-url.com

# How long each notification stays visible (milliseconds).
NOTIFICATION_DURATION_MS=10000

# Maximum number of notifications shown at once (1–10).
MAX_NOTIFICATIONS=5

# Play a sound when a notification arrives (true / false).
SOUND_ENABLED=true


# ── Dev / test mode ────────────────────────────────────────
# true  → connect to the real WebSocket server (production).
# false → use the dummy service: fires fake test notifications
#         on a timer so you can develop the UI without a server.
USE_REAL_WEBSOCKET=false

# How often the dummy service fires a notification (milliseconds).
# Only used when USE_REAL_WEBSOCKET=false.
DUMMY_INTERVAL_MS=5000


# ── Notification actions ────────────────────────────────────
# Mark-as-read API — called in 3 situations (real mode only):
#   1. Auto-dismiss (timer expires):  actionTaken = "Automatic Read"
#   2. Close button clicked:          actionTaken = "Manual Read"
#   3. Card body clicked:             actionTaken = "Manual Read"
# Payload: { "instance_id", "userSession", "isClicked": true, "actionTaken" }
# Skipped when user_id in the notification == -1.
MARK_AS_READ_URL=http://your-api-server.com/api/notifications/mark-read

# Snooze API (MARS) — called when snooze button is clicked (real mode only).
# Payload: { "instance_id", "userSession", "snoozeDurationMinutes" }
# Skipped when user_id in the notification == -1.
MARS_SNOOZE_URL=http://your-api-server.com/api/notifications/snooze

# Duration in minutes sent in the snooze payload.
SNOOZE_DURATION_MINUTES=5
