<Window x:Class="Nesti.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Nesti"
        Width="700"
        Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!--
        Fully transparent window.
        Click-through: WM_NCHITTEST returns HTTRANSPARENT for empty areas,
        HTCLIENT only for the bird zone and active notification cards.
    -->
    <Grid Background="Transparent">

        <!-- ── Notification stack ── -->
        <!-- Width matches NotificationControl.xaml (420) + panel margin -->
        <!-- bottom = BirdContainer top (158+5=163) + 10px gap = 173 -->
        <StackPanel x:Name="NotificationsPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,5,173"
                    Width="425" />

        <!-- ── Bird zone ── -->
        <Grid x:Name="BirdContainer"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,5,5"
              Width="160"
              Height="158"
              MouseEnter="BirdContainer_MouseEnter"
              MouseLeave="BirdContainer_MouseLeave">

            <!--
                Buttons float over the top-right corner of the bird GIF row.
                Styled exactly per ui.txt §7.1 (Button CSS Specifications):
                  • Background : #F9FAFB  (bg-gray-50)
                  • Border     : 1px solid #E5E7EB
                  • Shape      : rounded-full  (CornerRadius="9999")
                  • Padding    : 4px
                  • SVG icons  : 12×12 displayed in a 14×14 viewBox
                  • Hover bg   : #F3F4F6  (bg-gray-100)
                  • Hover border: #D1D5DB (border-gray-300)
                  • Stroke     : #6B7280, 1.5px, round line-caps
            -->
            <StackPanel x:Name="ControlButtons"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal"
                        Margin="0,22,4,0"
                        Visibility="Collapsed">

                <!-- Minimize / Hide button — SVG dash icon (M3,7 L11,7) -->
                <Button Margin="0,0,6,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Hide Nesti (shows again on next notification)"
                        Click="HideButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="9999"
                                    Padding="4">
                                <!-- Viewbox scales the 14×14 SVG coordinate space to 12×12 display -->
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="14" Height="14">
                                        <Path Data="M3,7 L11,7"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"   Value="#F3F4F6" />
                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#D1D5DB" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Close / exit button — SVG X icon (M10.5,3.5 L3.5,10.5 M3.5,3.5 L10.5,10.5) -->
                <Button Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Close Nesti"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="9999"
                                    Padding="4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="14" Height="14">
                                        <Path Data="M10.5,3.5 L3.5,10.5 M3.5,3.5 L10.5,10.5"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"   Value="#F3F4F6" />
                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#D1D5DB" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- ── animated bird — ui.txt spec: 150px width ── -->
            <Image gif:ImageBehavior.AnimatedSource="pack://application:,,,/assets/nest_bird.gif"
                   gif:ImageBehavior.RepeatBehavior="Forever"
                   Width="150" Height="150"
                   Stretch="Uniform"
                   Cursor="Hand"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   MouseLeftButtonDown="Bird_Click" />


        </Grid>

    </Grid>
</Window>
