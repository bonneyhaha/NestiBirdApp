<Window x:Class="Nesti.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Nesti"
        Width="700"
        Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!--
        Fully transparent window.
        Click-through: WM_NCHITTEST returns HTTRANSPARENT for empty areas,
        HTCLIENT only for the bird zone and active notification cards.

        BirdContainer uses two rows so control buttons are INSIDE its layout
        bounds — this is what fixes the "hover only half-works" bug:
          Row 0 (32px) : minimize + close buttons  ← always within bounds
          Row 1 (* )   : animated bird GIF
        GreetingBubble is checked explicitly in IsInteractive().
    -->
    <Grid Background="Transparent">

        <!-- ── Notification stack ── -->
        <StackPanel x:Name="NotificationsPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,5,200"
                    Width="390" />

        <!-- ── Bird zone ── -->
        <Grid x:Name="BirdContainer"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,5,5"
              Width="160"
              Height="190"
              MouseEnter="BirdContainer_MouseEnter"
              MouseLeave="BirdContainer_MouseLeave">

            <Grid.RowDefinitions>
                <RowDefinition Height="32" />   <!-- Row 0: control buttons -->
                <RowDefinition Height="*" />    <!-- Row 1: bird GIF        -->
            </Grid.RowDefinitions>

            <!-- ── Row 0: control buttons (PNG icons, always within bounds) ── -->
            <StackPanel x:Name="ControlButtons"
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Margin="0,0,4,0"
                        Visibility="Collapsed">

                <!-- Minimize button -->
                <Button Width="28" Height="28"
                        Margin="0,0,6,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Hide Nesti (shows again on next notification)"
                        Click="HideButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Image Source="pack://application:,,,/assets/minimize_button_icon.png"
                                   Width="26" Height="26"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Close / exit button -->
                <Button Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Close Nesti"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Image Source="pack://application:,,,/assets/cross_button_notif.png"
                                   Width="26" Height="26"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- ── Row 1: animated bird ── -->
            <Image Grid.Row="1"
                   gif:ImageBehavior.AnimatedSource="pack://application:,,,/assets/nest_bird.gif"
                   gif:ImageBehavior.RepeatBehavior="Forever"
                   Width="155" Height="155"
                   Stretch="Uniform"
                   Cursor="Hand"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   MouseLeftButtonDown="Bird_Click" />

            <!-- ── Greeting bubble (overlaid, extends left — checked explicitly in WM_NCHITTEST) ── -->
            <Border x:Name="GreetingBubble"
                    Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-90,155,0"
                    Width="300"
                    Background="#CCFFFFFF"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="16,12"
                    Visibility="Collapsed"
                    Opacity="0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.10"
                                      BlurRadius="8" ShadowDepth="3" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="Bold">
                        <Run Text="Hi, I'm " Foreground="#374151" />
                        <Run Text="Nesti!" Foreground="#1C38D4" />
                    </TextBlock>
                    <TextBlock x:Name="GreetingTextBlock"
                               FontSize="11"
                               Foreground="#6B7280"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap">
                        Your notification assistant
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
