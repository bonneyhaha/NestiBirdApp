<Window x:Class="Nesti.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nesti"
        Width="400"
        Height="175"
        SizeToContent="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!--
        Non-layered window (AllowsTransparency=False) eliminates the per-pixel-alpha
        DIB section that WS_EX_LAYERED + UpdateLayeredWindow requires. On high-DPI
        GPU machines this DIB section was the single largest memory consumer
        (700×700 at 200% DPI × 4 bpp × front+back buffers ≈ 30+ MB).

        Background="#01000000" (A=1/255) ensures WPF's software renderer writes
        near-transparent pixels for empty areas.  Window.Opacity=0.99 (set in
        code-behind) tells DWM to use LWA_ALPHA uniform compositing — no per-pixel
        buffer — so empty areas composite as virtually invisible against the desktop.

        Click-through behaviour is unchanged: WM_NCHITTEST returns HTTRANSPARENT
        for empty areas regardless of layering mode.
    -->
    <Grid>

        <!-- ── Notification stack ── -->
        <StackPanel x:Name="NotificationsPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,5,173"
                    Width="380" />

        <!-- ── Bird zone ── -->
        <Grid x:Name="BirdContainer"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,5,5"
              Width="160"
              Height="158"
              MouseEnter="BirdContainer_MouseEnter"
              MouseLeave="BirdContainer_MouseLeave">

            <StackPanel x:Name="ControlButtons"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal"
                        Margin="0,22,4,0"
                        Visibility="Collapsed">

                <!-- Hide button -->
                <Button Margin="0,0,6,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Hide Nesti (shows again on next notification)"
                        Click="HideButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="9999"
                                    Padding="4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="14" Height="14">
                                        <Path Data="M3,7 L11,7"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"  Value="#F3F4F6" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#D1D5DB" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Close button -->
                <Button Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Close Nesti"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="9999"
                                    Padding="4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="14" Height="14">
                                        <Path Data="M10.5,3.5 L3.5,10.5 M3.5,3.5 L10.5,10.5"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"  Value="#F3F4F6" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#D1D5DB" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- animated bird -->
            <Image x:Name="BirdImage"
                   Width="150" Height="150"
                   Stretch="Uniform"
                   Cursor="Hand"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   MouseLeftButtonDown="Bird_Click" />

        </Grid>

    </Grid>
</Window>
